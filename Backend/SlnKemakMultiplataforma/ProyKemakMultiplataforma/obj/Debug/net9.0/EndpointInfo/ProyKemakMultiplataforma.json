  "components": {
    "schemas": {
      "ClienteCreateDTO": {
        "required": [
          "dni",
          "nombre"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 100,
            "minLength": 3,
            "type": "string"
          },
          "dni": {
            "minLength": 1,
            "pattern": "^\\d{8,12}$",
            "type": "string"
          },
          "telefono": {
            "maxLength": 15,
            "minLength": 0,
            "type": "string",
            "format": "tel",
            "nullable": true
          },
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "direccion": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "DetalleVentaCreateDTO": {
        "type": "object",
        "properties": {
          "idItem": {
            "type": "integer",
            "format": "int32"
          },
          "cantidad": {
            "type": "integer",
            "format": "int32"
          },
          "precioUnitario": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "DevolucionToldoDTO": {
        "type": "object",
        "properties": {
          "idAlquiler": {
            "type": "integer",
            "format": "int32"
          },
          "observaciones": {
            "type": "string",
            "nullable": true
          },
          "estado": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ImagenReadDto": {
        "type": "object",
        "properties": {
          "idImagen": {
            "type": "integer",
            "format": "int32"
          },
          "url": {
            "type": "string",
            "nullable": true
          },
          "descripcion": {
            "type": "string",
            "nullable": true
          },
          "orden": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ImagenUpdateDto": {
        "type": "object",
        "properties": {
          "descripcion": {
            "type": "string",
            "nullable": true
          },
          "orden": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ProductoLicoreriaCreateDTO": {
        "required": [
          "nombre",
          "precio",
          "stock"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "marca": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "categoria": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "precio": {
            "maximum": 10000,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "stock": {
            "maximum": 5000,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ProductoLicoreriaDTO": {
        "type": "object",
        "properties": {
          "idProducto": {
            "type": "integer",
            "format": "int32"
          },
